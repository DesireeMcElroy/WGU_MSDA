    <worksheet name='State Spending'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Average State Spending per Capita</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='merged_cleaned_df' name='federated.0r35f5m0rrxqy018770ur0zrq1wm' />
          </datasources>
          <datasource-dependencies datasource='federated.0r35f5m0rrxqy018770ur0zrq1wm'>
            <column caption='Avg Readmission Rate' datatype='real' name='[Calculation_81416703666450440]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(IF [Readmission] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
            </column>
            <column datatype='real' name='[Length of Stay (days)]' role='measure' type='quantitative' />
            <column datatype='string' name='[Readmission]' role='dimension' type='nominal' />
            <column caption='Spending Per Capita1' datatype='real' name='[SPENDING_PER_CAPITA]' role='measure' type='quantitative' />
            <column datatype='string' name='[State Name]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='real' name='[Total Charge]' role='measure' type='quantitative' />
            <column-instance column='[Length of Stay (days)]' derivation='Avg' name='[avg:Length of Stay (days):qk]' pivot='key' type='quantitative' />
            <column-instance column='[SPENDING_PER_CAPITA]' derivation='Avg' name='[avg:SPENDING_PER_CAPITA:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Total Charge]' derivation='Avg' name='[avg:Total Charge:qk]' pivot='key' type='quantitative' />
            <column-instance column='[State Name]' derivation='None' name='[none:State Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_81416703666450440]' derivation='User' name='[usr:Calculation_81416703666450440:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.0r35f5m0rrxqy018770ur0zrq1wm].[avg:SPENDING_PER_CAPITA:qk]' included-values='non-null' />
          <filter class='categorical' column='[federated.0r35f5m0rrxqy018770ur0zrq1wm].[none:State Name:nk]'>
            <groupfilter function='union' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter from='&quot;Alabama&quot;' function='range' level='[none:State Name:nk]' to='&quot;Pennsylvania&quot;' />
              <groupfilter from='&quot;Rhode Island&quot;' function='range' level='[none:State Name:nk]' to='&quot;Wyoming&quot;' />
            </groupfilter>
          </filter>
          <computed-sort column='[federated.0r35f5m0rrxqy018770ur0zrq1wm].[none:State Name:nk]' direction='DESC' using='[federated.0r35f5m0rrxqy018770ur0zrq1wm].[avg:SPENDING_PER_CAPITA:qk]' />
          <slices>
            <column>[federated.0r35f5m0rrxqy018770ur0zrq1wm].[avg:SPENDING_PER_CAPITA:qk]</column>
            <column>[federated.0r35f5m0rrxqy018770ur0zrq1wm].[none:State Name:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
