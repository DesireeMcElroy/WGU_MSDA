        WHEN &apos;WA&apos; THEN &apos;Washington&apos;&#13;
        WHEN &apos;WV&apos; THEN &apos;West Virginia&apos;&#13;
        WHEN &apos;WI&apos; THEN &apos;Wisconsin&apos;&#13;
        WHEN &apos;WY&apos; THEN &apos;Wyoming&apos;&#13;
        ELSE NULL&#13;
        END AS &quot;State Name&quot;&#13;
&#13;
  , l.&quot;ZIP&quot;&#13;
  , l.&quot;County&quot;&#13;
  , s.&quot;Services&quot;&#13;
  , s.&quot;Overweight&quot;&#13;
  , s.&quot;Arthritis&quot;&#13;
  , s.&quot;Diabetes&quot;&#13;
  , s.&quot;Hyperlipidemia&quot;&#13;
  , s.&quot;Back Pain&quot;&#13;
  , s.&quot;Anxiety&quot;&#13;
  , s.&quot;Allergic Rhinitis&quot;&#13;
  , s.&quot;Reflux Esophagitis&quot;&#13;
  , s.&quot;Asthma&quot;&#13;
  , sr.&quot;Survey Item 1&quot;&#13;
  , sr.&quot;Survey Item 2&quot;&#13;
  , sr.&quot;Survey Item 3&quot;&#13;
  , sr.&quot;Survey Item 4&quot;&#13;
  , sr.&quot;Survey Item 5&quot;&#13;
  , sr.&quot;Survey Item 6&quot;&#13;
  , sr.&quot;Survey Item 7&quot;&#13;
  , sr.&quot;Survey Item 8&quot;&#13;
FROM patient_cleaned p&#13;
LEFT JOIN job j ON p.job_id = j.job_id&#13;
LEFT JOIN admission a ON p.admis_id = a.admins_id&#13;
LEFT JOIN complication c ON p.compl_id = c.complication_id&#13;
LEFT JOIN location l ON p.location_id = l.location_id&#13;
LEFT JOIN services s ON p.&quot;Patient ID&quot; = s.patient_id&#13;
LEFT JOIN survey sr ON p.&quot;Patient ID&quot; = sr.patient_id</relation>
