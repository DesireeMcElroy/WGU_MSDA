      <aliases enabled='yes' />
      <column caption='Income Group' datatype='string' name='[Calculation_81416637414047760]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Income] &lt; 20000 THEN &quot;Low Income&quot;&#10;ELSEIF [Income] &lt; 35000 THEN &quot;Lower-Mid Income&quot;&#10;ELSEIF [Income] &lt; 55000 THEN &quot;Upper-Mid Income&quot;&#10;ELSE &quot;High Income&quot;&#10;END' />
      </column>
      <column caption='Avg Readmission per $1,000 Spent' datatype='real' name='[Calculation_81416702583062534]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [Readmission] = &quot;Yes&quot; THEN 1 ELSE 0 END)) / &#10;(SUM([SPENDING_PER_CAPITA]) / 10000)' />
      </column>
      <column caption='Avg Charges per Day per Patient' datatype='real' name='[Calculation_81416703365910535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Charge]) / SUM([Length of Stay (days)])' />
      </column>
      <column caption='Avg Readmission Rate' datatype='real' name='[Calculation_81416703666450440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Readmission] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Selected Outcome Calc' datatype='real' name='[Calculation_81416703672639497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &quot;Readmission&quot; THEN AVG(IF [Readmission] = &quot;Yes&quot; THEN 1 ELSE 0 END)&#10;WHEN &quot;Length of Stay&quot; THEN AVG([Length of Stay (days)])&#10;WHEN &quot;Total Charge&quot; THEN AVG([Total Charge])&#10;END' />
      </column>
      <column caption='YAxis Label (Selected Outcome Calc)' datatype='string' name='[Calculation_81416705488371723]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &quot;Readmission&quot; THEN &quot;Avg Readmission Rate&quot;&#10;WHEN &quot;Length of Stay&quot; THEN &quot;Avg Length of Stay&quot;&#10;WHEN &quot;Total Charges&quot; THEN &quot;Avg Total Charges&quot;&#10;END' />
        <aliases>
          <alias key='%null%' value='Total Charge' />
        </aliases>
      </column>
      <column caption='Condition Name' datatype='string' name='[Calculation_81416705691062286]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Diabetes] = &quot;Yes&quot; THEN &quot;Diabetes&quot;&#10;ELSEIF [Stroke] = &quot;Yes&quot; THEN &quot;Stroke&quot;&#10;ELSEIF [Asthma] = &quot;Yes&quot; THEN &quot;Asthma&quot;&#10;ELSEIF [Overweight] = &quot;Yes&quot; THEN &quot;Overweight&quot;&#10;ELSEIF [High Blood Pressure] = &quot;Yes&quot; THEN &quot;High Blood Pressure&quot;&#10;END' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[County]' role='dimension' semantic-role='[County].[Name]' type='nominal' />
      <column aggregation='Avg' datatype='real' name='[Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='None' datatype='integer' name='[Length of Stay (days) (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='0' formula='[Length of Stay (days)]' peg='0' size='1.26' />
      </column>
      <column datatype='real' name='[Length of Stay (days)]' role='measure' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column caption='Spending Per Capita1' datatype='real' name='[SPENDING_PER_CAPITA]' role='measure' type='quantitative' />
      <column caption='State1' datatype='string' name='[STATE]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column datatype='string' name='[State Name]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column aggregation='Sum' datatype='integer' default-format='*00000' name='[ZIP]' role='dimension' semantic-role='[ZipCode].[Name]' type='ordinal' />
      <_.fcp.ObjectModelTableType.true...column caption='Custom SQL Query' datatype='table' name='[__tableau_internal_object_id__].[_CEE53EBEC67346D8849FD6EBD5076926]' role='measure' type='quantitative' />
      <layout _.fcp.SchemaViewerObjectModel.false...dim-percentage='0.5' _.fcp.SchemaViewerObjectModel.false...measure-percentage='0.4' dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
