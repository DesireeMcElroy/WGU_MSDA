            <format attr='text-format' field='[federated.0r35f5m0rrxqy018770ur0zrq1wm].[avg:Total Charge:qk]' value='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
