    <worksheet name='Sheet 8'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='16'>Total Charges versus Income Group</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='merged_cleaned_df' name='federated.0r35f5m0rrxqy018770ur0zrq1wm' />
          </datasources>
          <datasource-dependencies datasource='federated.0r35f5m0rrxqy018770ur0zrq1wm'>
            <column caption='Income Group' datatype='string' name='[Calculation_81416637414047760]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Income] &lt; 20000 THEN &quot;Low Income&quot;&#10;ELSEIF [Income] &lt; 35000 THEN &quot;Lower-Mid Income&quot;&#10;ELSEIF [Income] &lt; 55000 THEN &quot;Upper-Mid Income&quot;&#10;ELSE &quot;High Income&quot;&#10;END' />
            </column>
            <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
