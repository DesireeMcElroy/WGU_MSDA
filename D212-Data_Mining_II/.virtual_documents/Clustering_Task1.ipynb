


# imports
import pandas as pd
import numpy as np

import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.preprocessing import StandardScaler
from sklearn.preprocessing import RobustScaler














# load
df = pd.read_csv("medical_clean.csv")

df.columns = df.columns.str.lower()
df.info()





df.head(3).T


cols = []
for i in df.columns:
    if df[i].nunique()>2:
        cols.append(i)
        
cols


identifier_cols = ['caseorder',
                   'customer_id',
                   'interaction',
                   'uid']

cont_cols = [
             'population',
             'children',
             'age',
             'income',
             'vitd_levels',
             'doc_visits',
             'full_meals_eaten',
             'vitd_supp',
             'initial_days',
             'totalcharge',
             'additional_charges',
                ]
for i in cont_cols:
    if df[i].nunique()<10:
        print(i)
        print(df[i].value_counts())
        print('---------')


cont_cols.remove('vitd_supp')
cont_cols


cont_df = df[cont_cols]

rename = {'totalcharge':'total_charges'}
cont_df = cont_df.rename(columns=rename)

cont_df.dtypes


for i in cont_df.columns:
    plt.title(i)
    sns.boxplot(data=cont_df, x=i)
    plt.grid(linewidth=0.3)
    plt.show()


# scale
scaler = StandardScaler()
X_scaled = scaler.fit_transform(cont_df)

# save cleaned dataset
cleaned_df = pd.DataFrame(X_scaled, columns=cont_df.columns)
cleaned_df.to_csv("patient_info_cleaned.csv", index=False)





from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score


# elbow method
inertia = []
for k in range(2,12):
  km = KMeans(n_clusters=k, random_state=42)
  km.fit(X_scaled)
  inertia.append(km.inertia_)

plt.plot(range(2,12), inertia, marker='o')
plt.xlabel("Clusters")
plt.ylabel("Inertia")
plt.show()


robust = RobustScaler()
robust_df = robust.fit_transform(cont_df)

for i in range(3,10):
    # silhouette example
    km = KMeans(n_clusters=i, random_state=42).fit(robust_df)
    labels = km.labels_
    score = silhouette_score(robust_df, labels)
    print(f'Num Clusters {i} Silhouette score: {score}')


for i in range(3,10):
    # silhouette example
    km = KMeans(n_clusters=i, random_state=42).fit(X_scaled)
    labels = km.labels_
    score = silhouette_score(X_scaled, labels)
    print(f'Num Clusters {i} Silhouette score: {score}')





## try non scaled

cont_df.describe()


for i in range(3,10):
    # silhouette example
    km = KMeans(n_clusters=i, random_state=42).fit(cont_df)
    labels = km.labels_
    score = silhouette_score(cont_df, labels)
    print(f'Num Clusters {i} Silhouette score: {score}')


## scaling only large range vals
wide_range_vals = ['population','total_charges','additional_charges']


# scale
scaler = StandardScaler()
scaled_df = scaler.fit_transform(cont_df[wide_range_vals])





cont_df


pd.DataFrame(scaled_df, columns=wide_range_vals)


temp1 = pd.DataFrame(scaled_df, columns=wide_range_vals)
temp2 = cont_df.drop(columns=wide_range_vals)

final_df = temp1.merge(temp2,
                left_index=True,
                right_index=True)





for i in range(3,10):
    # silhouette example
    km = KMeans(n_clusters=i, random_state=42).fit(final_df)
    labels = km.labels_
    score = silhouette_score(final_df, labels)
    print(f'Num Clusters {i} Silhouette score: {score}')



# elbow method
inertia = []
for k in range(2,12):
  km = KMeans(n_clusters=k, random_state=42)
  km.fit(final_df)
  inertia.append(km.inertia_)

plt.plot(range(2,12), inertia, marker='o')
plt.xlabel("Clusters")
plt.ylabel("Inertia")
plt.show()


km = KMeans(n_clusters=5, random_state=42).fit(final_df)
labels = km.labels_
score = silhouette_score(final_df, labels)
print(f'Num Clusters {i} Silhouette score: {score}')


final_df['cluster_group'] = labels

final_df.cluster_group.value_counts()





cont_df['cluster_group'] = final_df.cluster_group

cont_df.dtypes


features = [
    "population","children","age","income","vitd_levels",
    "doc_visits","full_meals_eaten","initial_days",
    "total_charges","additional_charges"
]

df_scaled = cont_df.copy()
df_scaled[features] = StandardScaler().fit_transform(cont_df[features])


cluster_means = (
    df_scaled
    .groupby("cluster_group")[features]
    .mean()
)

plt.figure(figsize=(12,6))
sns.heatmap(
    cluster_means,
    cmap="coolwarm",
    center=0,
    linewidths=0.5
)
plt.title("Cluster Feature Profiles (Means)")
plt.ylabel("Cluster")
plt.xlabel("Feature")
plt.show()


















