        <zone flipboard-zone-id='5' forceUpdate='true' h='70539' hidden='true' id='7' story-point-id='5' type-v2='text' w='92126' x='4331' y='14523'>
          <formatted-text>
            <run bold='true' fontname='Tableau Light' fontsize='18'>Final Takeaways</run>
            <run>Æ&#10;</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>     - Higher spending does </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>not guarantee</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'> better patient outcomes.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>     - Complication risk and readmitted patients have a </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>major impact</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'> on costs.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>     - Income group differences in charges and access were </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>minimal</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>     - </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Tableau Light' fontsize='18'>Focused risk management can lower readmissions and cut unnecessary costs.</run>
          </formatted-text>
        </zone>
      </zones>
